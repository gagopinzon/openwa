# Copiar a .env y completar valores.
# Puerto del servidor Express
PORT=3445

# Modo simulación (no envía por WhatsApp real)
TEST_MODE=false

# API key de DeepSeek para generar mensajes con IA
DEEPSEEK_API_KEY=

# OpenWA — gateway en openwa.protalentconnections.com
OPENWA_BASE_URL=https://whatsapp.protalentconnections.com/api
OPENWA_API_KEY=owa_k1_598c8ea2bdd781762b89d47dfa1ee7dc65c1e8f054bab172db0fad0ad25d82f4

# Las sesiones WhatsApp se configuran en la interfaz web (se guardan en data/sessions.json).
# Solo si el archivo está vacío al primer arranque, se importan desde estas variables:
# OPENWA_SESSION_SESSION1=
# OPENWA_SESSION_SESSION2=
# OPENWA_SESSION_SESSION3=
# OPENWA_SESSION_ID=

# Historial de contactos (base separada del proyecto Puppeteer)
# MONGODB_URI=mongodb://whatsapp_app:TU_PASSWORD@localhost:27017/whatsapp_bulk_openwa?authSource=whatsapp_bulk_openwa
# MONGODB_URI=
